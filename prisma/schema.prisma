generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String
  name                 String?
  role                 Role           @default(USER)
  credits              Int            @default(0)
  planId               String?
  plan                 Plan?          @relation(fields: [planId], references: [id])
  stripeCustomerId     String?        @unique
  stripeSubscriptionId String?        @unique
  telegramChatId       String?
  emailVerified        Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  submissions          Submission[]
  apiKeys              ApiKey[]
  creditLogs           CreditLog[]
  dripCampaigns        DripCampaign[]

  @@index([email])
}

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique
  slug            String   @unique
  price           Int
  creditsPerMonth Int
  stripePriceId   String?
  features        String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  users           User[]
}

model Submission {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  url           String
  status        IndexStatus  @default(PENDING)
  method        IndexMethod  @default(GOOGLE_API)
  googleJobId   String?
  indexedAt     DateTime?
  lastCheckedAt DateTime?
  errorMessage  String?
  creditsCost   Int          @default(1)
  source        String       @default("dashboard")
  dripCampaignId String?
  dripCampaign  DripCampaign? @relation(fields: [dripCampaignId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([dripCampaignId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  usageCount Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@index([userId])
}

model CreditLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta        Int
  reason       String
  referenceId  String?
  balanceAfter Int
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ── Drip Campaign ─────────────────────────────────────────────────────────────

model DripCampaign {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  status         DripStatus     @default(ACTIVE)
  method         IndexMethod    @default(GOOGLE_API)
  urls           String[]       // full list of URLs in the campaign
  urlsSubmitted  Int            @default(0)
  urlsTotal      Int
  urlsPerDay     Int            @default(50)
  minDelayMin    Int            @default(5)   // min minutes between submissions
  maxDelayMin    Int            @default(60)  // max minutes between submissions
  smartDrip      Boolean        @default(true) // randomize within window
  windowStartHour Int           @default(9)   // smart drip window start (user local hour)
  windowEndHour  Int            @default(17)  // smart drip window end
  userTimezone   String         @default("UTC")
  creditsReserved Int           @default(0)
  nextRunAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  submissions    Submission[]

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
}

// ── Google Service Account ────────────────────────────────────────────────────

model GoogleServiceAccount {
  id              String    @id @default(cuid())
  label           String
  credentialsJson String    // encrypted JSON blob of service account key
  clientEmail     String
  isActive        Boolean   @default(true)
  isHealthy       Boolean   @default(true)
  dailyQuota      Int       @default(200)
  quotaUsed       Int       @default(0)
  quotaResetAt    DateTime?
  lastHealthCheck DateTime?
  lastUsedAt      DateTime?
  priority        Int       @default(0) // higher = tried first
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, isHealthy, quotaUsed])
}

enum Role {
  USER
  ADMIN
}

enum IndexStatus {
  PENDING
  QUEUED
  SUBMITTED
  CRAWLED
  INDEXED
  FAILED
  SKIPPED
}

enum IndexMethod {
  GOOGLE_API
  SITEMAP_PING
  FETCH_AS_GOOGLE
  INDEXNOW
}

enum DripStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}


model IndexNowKey {
  id          String    @id @default(cuid())
  label       String
  apiKey      String
  host        String
  keyLocation String
  isActive    Boolean   @default(true)
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
}
