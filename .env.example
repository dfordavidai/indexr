# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://indexr:indexr_secret@localhost:5432/indexr

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used by Bull for the indexing queue
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-random-secret

# ─── Google Indexing API ──────────────────────────────────────────────────────
# Service account JSON (entire JSON as a single-line string)
# Create at: https://console.cloud.google.com → IAM → Service Accounts
# Grant "Owner" role in Google Search Console for each property
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"indexr@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Google Custom Search (for index status checking) ────────────────────────
# Optional: used to check if a URL appears in Google search results
# Get at: https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# ─── IndexNow (fallback indexing) ────────────────────────────────────────────
# Any UUID or alphanumeric key; also host the key file at /<key>.txt on your domain
INDEXNOW_API_KEY=

# ─── InstantIndexer (Link Submit) ────────────────────────────────────────────
# API key from https://instantindexer.org/dashboard.php
# Used exclusively by the "Link Submit" tab to send URLs for indexing.
# Normal mode costs 1 credit/URL; Instant mode costs 10 credits/URL.
INSTANT_INDEXER_API_KEY=iix_your_api_key_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get at: https://dashboard.stripe.com/webhooks (add endpoint: /api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each paid plan (create in Stripe dashboard)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ─── Email ────────────────────────────────────────────────────────────────────
# Option 1: Resend (recommended) — https://resend.com
RESEND_API_KEY=re_...

# Option 2: SMTP (fallback if RESEND_API_KEY is not set)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=your-smtp-password

# From address for outgoing emails
EMAIL_FROM=Indexr <noreply@indexr.io>

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot at: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Used by the seed script to create the initial admin account
ADMIN_EMAIL=admin@indexr.io
ADMIN_PASSWORD=change-me-in-production

# ─── Docker (optional overrides for docker-compose) ──────────────────────────
POSTGRES_USER=indexr
POSTGRES_PASSWORD=indexr_secret
POSTGRES_DB=indexr
